# Apollo Configuration for Docker
# Use Theta RAG instead of local Ollama (not enough RAM)

# ============================================================================
# DeepSeek Configuration - Use Theta EdgeCloud
# ============================================================================
DEEPSEEK_PROVIDER=theta
THETA_API_KEY=${THETA_API_KEY}
THETA_DEEPSEEK_ENDPOINT=https://api.thetaedgecloud.com/v1/models/deepseek-coder-33b

# Fallback to Theta RAG if Theta GPU not available
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-coder:33b

# ============================================================================
# Theta RAG Configuration
# ============================================================================
THETA_RAG_ENABLED=true
THETA_RAG_API_KEY=${THETA_API_KEY}
THETA_RAG_ENDPOINT=https://api.thetaedgecloud.com/v1/rag

# ============================================================================
# Database Connections
# ============================================================================
MONGODB_URL=mongodb://mongo:27017
QUESTDB_URL=http://questdb:9000
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlas_dev_password
POSTGRES_URL=postgresql://atlas:atlas_dev_password@postgres:5432/atlas

# ============================================================================
# Kafka
# ============================================================================
KAFKA_BROKERS=kafka:9092

# ============================================================================
# Linear Integration
# ============================================================================
LINEAR_API_KEY=${LINEAR_API_KEY}
LINEAR_WORKSPACE_ID=${LINEAR_WORKSPACE_ID}

# ============================================================================
# GitHub Integration
# ============================================================================
GITHUB_TOKEN=${GITHUB_TOKEN}

# ============================================================================
# Slack/Email Notifications
# ============================================================================
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_URL}
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}

# ============================================================================
# Documentation Consolidation Service
# ============================================================================
DOCS_WATCH_PATHS=/workspace/docs,/workspace/Atlas/docs,/workspace/Apollo/docs,/workspace/Akashic/docs
DOCS_CONSOLIDATION_INTERVAL=300  # 5 minutes
DOCS_OUTPUT_PATH=/workspace/consolidated_docs

# ============================================================================
# PM Service Configuration
# ============================================================================
PM_SERVICE_ENABLED=true
PM_AUTO_CREATE_TICKETS=true
PM_AUTO_UPDATE_TICKETS=true
PM_SYNC_INTERVAL=600  # 10 minutes
